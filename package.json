{
  "name": "odyssee",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "contrast-audit": "node scripts/contrast-audit.mjs",
    "validate-seed": "npx tsx scripts/validate-seed.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run contrast-audit && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@serwist/next": "^9.5.11",
    "dexie": "^4.4.3",
    "lz-string": "^1.5.0",
    "maplibre-gl": "^5.24.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "serwist": "^9.5.11",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lz-string": "^1.3.34",
    "@types/maplibre-gl": "^1.13.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
