# ─────────────────────────────────────────────────────────────────────────
# Odyssée — variables d'environnement (toutes optionnelles → mode MOCK)
# Copier en .env.local et renseigner ce dont vous avez besoin.
# ─────────────────────────────────────────────────────────────────────────

# Mode applicatif : "mock" (défaut, hors-ligne, déterministe) ou "live".
NEXT_PUBLIC_APP_MODE=mock

# Claude API (génération IA). Absent → mode MOCK déterministe.
ANTHROPIC_API_KEY=

# Open Charge Map (chargeurs). Absent → seed embarqué.
OPENCHARGEMAP_API_KEY=

# OpenAgenda — événements datés pour la synthèse (S3). Absent → mock.
# Clé publique gratuite : https://developers.openagenda.com
OPENAGENDA_PUBLIC_KEY=

# ── Disponibilité hôtels (R5) ──────────────────────────────────────────────
# Amadeus Self-Service (Hotel Search), palier gratuit. Absent → mock déterministe.
# Serveur uniquement. https://developers.amadeus.com
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
# Alternative (optionnelle) — non activée par défaut.
LITEAPI_KEY=
# TTL du cache de disponibilité (s) — préserve le quota gratuit. Défaut 600.
LODGING_AVAILABILITY_TTL_SECONDS=600

# ── Tesla Fleet API ────────────────────────────────────────────────────────
# Flux OAuth complet (recommandé). Toutes serveur uniquement.
# Obtenues sur https://developer.tesla.com (voir docs/TESLA.md).
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=
# URI de redirection enregistrée dans la console Tesla Developer.
# Doit pointer vers cette route exacte :
TESLA_REDIRECT_URI=https://votre-domaine.example/api/tesla/callback
# Clé 32+ caractères pour chiffrer (AES-256-GCM) les jetons dans le cookie.
# Générer : openssl rand -base64 32
TESLA_TOKEN_SECRET=
# Clé publique de domaine (PEM), servie sous /.well-known/... pour Tesla.
TESLA_PUBLIC_KEY_PEM=

# Base régionale Fleet API. Optionnelle : découverte automatiquement via
# /api/1/users/region. Sert d'indice et d'audience pour l'enregistrement.
#   Europe        : https://fleet-api.prd.eu.vn.cloud.tesla.com
#   Amérique Nord : https://fleet-api.prd.na.vn.cloud.tesla.com
TESLA_FLEET_API_BASE=

# Override dev UNIQUEMENT : jeton d'accès statique (court-circuite l'OAuth).
# Redondant avec le flux OAuth complet — NE PAS poser en production (Vercel).
# Expire ~8 h, pas de rafraîchissement.
TESLA_ACCESS_TOKEN=

# TTL du cache d'état véhicule (s). Plafonne le coût Fleet API. Défaut 300.
TESLA_STATE_CACHE_TTL_SECONDS=300
